# Template de variaveis de ambiente do projeto.
# Copie este arquivo para .env e preencha com os valores reais.
# NUNCA coloque chaves ou segredos reais neste arquivo (.env.example e versionado no Git).

# --- LLM / OpenAI (opcional: o pipeline principal usa Ollama local) ---
OPENAI_API_KEY=sua_chave_openai_aqui

# --- Azure (Etapa 6 - arquitetura alvo) ---
AZURE_KEY_VAULT_ENDPOINT=https://seu-key-vault.vault.azure.net/
AZURE_TENANT_ID=seu_tenant_id_aqui

# --- Configuracoes gerais ---
ENV=development
LOG_LEVEL=INFO
